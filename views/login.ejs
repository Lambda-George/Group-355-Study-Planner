<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body>
    <%- include('./partials/nav.ejs') %>

    <div class="test-blog-thingy">
      <h2>Blog Test</h2>

      <% if (blogs.length > 0) { %> 

        <% blogs.forEach(blog => { %>
         <h3 class="blog"><%= blog.header %></h3>
         <p class="snippet"><%= blog.snippet %></p>
        <% }) %>

      <% } else { %> 
        
        <p>No blogs</p>
    
      <% } %>
    </div>

    <%- include('./partials/footer.ejs') %>
  </body>
</html>