<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body class="login-body">
    <%- include('./partials/nav.ejs') %>

    <main class="login-page">
      <header class="login-header">
        <h1 class="login-title">Enter Your Details</h1>
      </header>

      <section class="login-layout" aria-label="Login">
      
          <form class="login-form">
            <div class="login-form-div">
              <label class="login-form-label" for="loginUsername">Username</label>
              <input
                type="text"
                id="loginUsername"
                name="username"
                class="login-form-input"
                placeholder="Username"
                autocomplete="username"
              />
            </div>

            <div class="login-form-div">
              <label class="login-form-label" for="loginPassword">Password</label>
              <input
                type="password"
                id="loginPassword"
                name="password"
                class="login-form-input"
                placeholder="Password"
                autocomplete="current-password"
              />
            </div>

            <button class="login-form-btn" type="submit">Log in</button>
          </form>
        </div>
      </section>
    </main>

    <%- include('./partials/footer.ejs') %>
  </body>
</html>
